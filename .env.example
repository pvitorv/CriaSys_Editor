APP_NAME=CriaSys_Editor
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# Laragon/Windows (opcional — local já desativa SSL verify automaticamente)
# HTTP_VERIFY_SSL=false

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# BANCO DE DADOS — configure com os dados do SEU ambiente (nunca use o .env de outra pessoa)
# =============================================================================
#
# Opção A — MySQL/MariaDB (recomendado: Laragon, XAMPP, Docker, servidor local)
# 1. Crie um banco vazio (ex.: HeidiSQL, phpMyAdmin, "mysql -u root -e 'CREATE DATABASE criasys_editor'")
# 2. Descomente e preencha:
#
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=criasys_editor
# DB_USERNAME=root
# DB_PASSWORD=
#
# Opção B — SQLite (teste rápido, sem instalar MySQL)
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite
#
# Padrão abaixo = SQLite. Troque para mysql se usar Laragon.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=criasys_editor
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# APIs de mídia (opcional — preencha quando tiver chaves)
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=

# TTS
TTS_DEFAULT_ENGINE=edge
TTS_DEFAULT_VOICE=pt-BR-FranciscaNeural
# COQUI_PYTHON=python
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# OPENAI_API_KEY=
# OPENAI_TTS_VOICE=nova

# Paths locais (vazio = storage/app/criasys/...)
CRIASYS_PROJECTS_PATH=
CRIASYS_EXPORTS_PATH=

# FFmpeg (vazio = usar ffmpeg/ffprobe do PATH)
FFMPEG_PATH=
FFPROBE_PATH=

# =============================================================================
# ADMINISTRADOR INICIAL (UserDev) — credenciais do SEU PC, não do mantenedor do repo
# =============================================================================
# Usado pelo seeder na primeira vez: php artisan migrate --seed
# Cada desenvolvedor/máquina define login e senha próprios. O .env NÃO vai para o GitHub.
#
ADMIN_USERNAME=UserDev
ADMIN_EMAIL=seu-email@exemplo.com
ADMIN_PASSWORD=

# Hash de senhas
HASH_DRIVER=argon2id
ARGON_MEMORY=131072
ARGON_THREADS=2
ARGON_TIME=4
